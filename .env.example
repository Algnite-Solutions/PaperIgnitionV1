# Database
DB_HOST=pgm-xxx.pg.rds.aliyuncs.com
DB_PORT=5432
DB_USER=paperignition
DB_PASSWORD=
DB_NAME_PAPER=paperignition
DB_NAME_USER=paperignition_user

# Embedding (DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM
GEMINI_API_KEY=

# Storage (Aliyun OSS)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=paperignition1

# Optional (PDF fallback via VolcEngine OCR)
VOLCENGINE_AK=
VOLCENGINE_SK=

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=PaperIgnition <your-support@gmail.com>

# Security
JWT_SECRET_KEY=             # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_TOKEN=              # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CORS_ALLOW_ORIGINS=https://paperignition.com,https://www.paperignition.com

# App
APP_SERVICE_HOST=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PAPERIGNITION_LOCAL_MODE=false

BAIDU_OCR_URL=your_url_here
BAIDU_OCR_TOKEN=your_token_here